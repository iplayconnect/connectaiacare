# ConnectaIACare — Template de PRODUÇÃO para Hostinger
# ------------------------------------------------------------
# Este arquivo é um TEMPLATE. No deploy, copiar para .env e preencher os
# campos marcados com <<<PREENCHER>>>.
#
# Backend faz fail-closed em produção (settings.py __post_init__):
#   - SECRET_KEY ≥ 32 chars (gerar com `openssl rand -hex 32`)
#   - ALLOWED_ORIGINS sem wildcard
#   - API keys do provider ativo obrigatórias
#
# NUNCA commitar um .env real. Só .env.production.template.

# ─── Ambiente ───────────────────────────────────────────────
ENV=production
DEBUG=false

# ─── Segurança ──────────────────────────────────────────────
# Gerar com: openssl rand -hex 32
SECRET_KEY=<<<PREENCHER_OPENSSL_RAND_HEX_32>>>

# Lista explícita de origens autorizadas (CORS).
ALLOWED_ORIGINS=https://care.connectaia.com.br,https://demo.connectaia.com.br

# HMAC secret para validar webhook Evolution (opcional mas recomendado).
# Gerar com: openssl rand -hex 24
EVOLUTION_WEBHOOK_SECRET=<<<PREENCHER_OPENSSL_RAND_HEX_24>>>

# ─── Banco de dados ─────────────────────────────────────────
# Hostnames internos da rede Docker `connectaiacare_internal`.
# POSTGRES_PASSWORD é carregada também pelo compose como variável de host.
DATABASE_URL=postgresql://postgres:<<<PREENCHER_POSTGRES_PASSWORD>>>@postgres:5432/connectaiacare
REDIS_URL=redis://redis:6379/5

# Também precisa estar exportada no shell antes do `docker compose up`
# ou no arquivo .env na RAIZ do projeto (não dentro de backend/).
# POSTGRES_PASSWORD=<<<PREENCHER_POSTGRES_PASSWORD>>>

# ─── Evolution API (WhatsApp) ────────────────────────────────
# Evolution API compartilhado com ConnectaIA (ADR-002)
# Instância DEDICADA (chip próprio 5551994548043, ADR-013)
EVOLUTION_API_URL=https://evolution.connectaia.com.br
EVOLUTION_API_KEY=691B4993E3BE-494B-BA0B-7108B9634E26
EVOLUTION_INSTANCE=Connectaiacare

# ─── IA ─────────────────────────────────────────────────────
LLM_PROVIDER=gemini

# Google Gemini 2.5 Flash (escolhido pela disponibilidade e custo)
GOOGLE_API_KEY=<<<PREENCHER_GOOGLE_API_KEY>>>

# Anthropic pode ser preenchido depois quando a Stripe da Anthropic normalizar.
ANTHROPIC_API_KEY=

# Deepgram (STT pt-BR)
DEEPGRAM_API_KEY=<<<PREENCHER_DEEPGRAM_API_KEY>>>

# Sofia Voz — chamadas proativas de voz (ADR-020)
# Rede interna Docker (infra_proxy): não precisa HTTPS/mTLS, só hostname
SOFIA_VOICE_API_URL=http://sofia-service:5030
SOFIA_VOICE_API_KEY=<<<PREENCHER_SOFIA_API_KEY>>>

# MedMonitor / TotalCare API (ADR-019)
# Tenant: vf-totalcare (Tecnosenior), fornecido 2026-04-20
MEDMONITOR_API_URL=https://vf-totalcare.contactto.care/agent
MEDMONITOR_API_KEY=<<<PREENCHER_MEDMONITOR_API_KEY>>>

# ─── Outros ────────────────────────────────────────────────
PUBLIC_BASE_URL=https://demo.connectaia.com.br
LOG_LEVEL=INFO
TENANT_ID=connectaiacare_demo
