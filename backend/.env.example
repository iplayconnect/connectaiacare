# ConnectaIACare — Variáveis de ambiente (exemplo)
# Copie para backend/.env e preencha.
# Em produção (ENV=production), o backend faz fail-closed se variáveis críticas
# não estiverem setadas corretamente (ver SECURITY.md §7, FINDING-001/002/008).

# ─── Ambiente ───────────────────────────────────────────────
# Valores aceitos: development | staging | production | prod
ENV=development

# true apenas em dev. Produção rejeita no startup.
DEBUG=true

# ─── Segurança ──────────────────────────────────────────────
# OBRIGATÓRIO em produção. Gerar com: openssl rand -hex 32
# Em dev, deixar vazio autogenera um secret temporário.
SECRET_KEY=

# OBRIGATÓRIO em produção (lista explícita, sem wildcard).
# Em dev, deixar vazio auto-popula localhost:3000,3030,5055.
ALLOWED_ORIGINS=

# Secret opcional para validar webhook do Evolution (HMAC).
# Se preenchido, webhook com assinatura inválida será rejeitado.
EVOLUTION_WEBHOOK_SECRET=

# ─── Banco de dados ─────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/connectaiacare
REDIS_URL=redis://localhost:6380/5

# ─── Evolution API (WhatsApp) ────────────────────────────────
# Evolution API compartilhado com ConnectaIA (mesmo container evolution_v2).
# Instância DEDICADA ao ConnectaIACare (chip próprio: 5551994548043).
# Decisão em ADR-013.
EVOLUTION_API_URL=https://evolution.connectaia.com.br
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=connectaiacare

# ─── IA ─────────────────────────────────────────────────────
# Provider do LLM: "anthropic" (default) | "gemini"
# Em produção, OBRIGATÓRIO setar a key correspondente ao provider ativo.
LLM_PROVIDER=anthropic

# Anthropic Claude (default — análise clínica, extração de entidades)
ANTHROPIC_API_KEY=

# Google Gemini (alternativa — usar com LLM_PROVIDER=gemini)
# Chave gratuita em https://aistudio.google.com/apikey (tier free 1500 RPD)
GOOGLE_API_KEY=

# Deepgram (STT pt-BR nova-2) — NÃO muda entre providers
DEEPGRAM_API_KEY=

# Sofia Voz (ligações proativas via Grok). Opcional em dev.
# Em rede Docker interna use hostname: http://sofia-service:5030
SOFIA_VOICE_API_URL=
SOFIA_VOICE_API_KEY=

# MedMonitor / TotalCare API (ADR-019)
# Base URL formato: https://<tenant>.contactto.care/agent
# Auth: Api-Key <key> no header Authorization
MEDMONITOR_API_URL=
MEDMONITOR_API_KEY=

# ─── Autenticação (JWT) ────────────────────────────────────
# JWT_SECRET é a chave HMAC-SHA256 dos tokens. Se vazio, usa SECRET_KEY como
# fallback (em prod, SECRET_KEY já é obrigatório, então JWT funciona out-of-the-box).
# Se quiser rotacionar JWT sem invalidar Flask sessions, setar JWT_SECRET separado.
JWT_SECRET=
# TTL do access token (segundos). 86400 = 24h.
JWT_EXP_SECONDS=86400
# Validade do refresh token (dias).
JWT_REFRESH_DAYS=7

# Liga/desliga middleware de auth em /api/*. DEFAULT=false durante a migração
# de páginas SSR (que fazem fetch server-side sem Bearer) para client fetch.
# O middleware Next.js já bloqueia o frontend. Ligar pra true quando todas as
# páginas tiverem migrado e a CI passar com auth obrigatório.
AUTH_ENFORCE=false

# Auto-seed do super_admin e parceiro no startup (idempotente).
# Setar como false depois que os usuários existirem para não tentar recriar.
AUTH_SEED_ON_STARTUP=true

# Super admin inicial — Alexandre, acesso total cross-tenant.
HEALTH_ADMIN_EMAIL=
HEALTH_ADMIN_PASSWORD=
HEALTH_ADMIN_NAME=Alexandre

# Parceiro inicial — Murilo (Tecnosenior). Escopo restrito definido no DB depois.
HEALTH_PARTNER_EMAIL=
HEALTH_PARTNER_PASSWORD=
HEALTH_PARTNER_NAME=Murilo
HEALTH_PARTNER_ORG=Tecnosenior

# ─── Sofia Care (sub-serviço de IA conversacional) ──────────
# URL interna do sofia-service (rede Docker). Em dev local: http://localhost:5031
SOFIA_SERVICE_URL=http://sofia-service:5031
# Chave compartilhada api ↔ sofia-service (segunda camada após JWT do api).
# Gerar com `openssl rand -hex 32`. Vazio em dev = sem check.
SOFIA_INTERNAL_KEY=
# ─── Sofia LLM models (família 3 = qualidade pra saúde) ──
# Default Sofia (cuidador/familiar/admin/paciente):
#   gemini-3-flash-preview — preview família 3, qualidade Pro a preço Flash
# Fallback automático: gemini-2.5-flash GA estável
SOFIA_LLM_MODEL=gemini-3-flash-preview
SOFIA_LLM_FALLBACK=gemini-2.5-flash
# Agente clínico (médico/enfermeiro): default Pro pra raciocínio profundo
SOFIA_CLINICAL_MODEL=gemini-3.1-pro-preview
# Voz real-time (Sofia.4 Live API): substitui Ultravox+Deepgram+ElevenLabs
SOFIA_VOICE_MODEL=gemini-3.1-flash-live-preview
# Modelo TTS (preview Gemini)
SOFIA_TTS_MODEL=gemini-2.5-flash-preview-tts
SOFIA_TTS_VOICE=Kore
# Sub-agent clínico pode usar modelo Pro pra raciocínio (opcional)
SOFIA_CLINICAL_MODEL=

# ─── Outros ────────────────────────────────────────────────
PUBLIC_BASE_URL=https://demo.connectaia.com.br
LOG_LEVEL=INFO
TENANT_ID=connectaiacare_demo
