# ConnectaIACare — Variáveis de ambiente (exemplo)
# Copie para backend/.env e preencha.
# Em produção (ENV=production), o backend faz fail-closed se variáveis críticas
# não estiverem setadas corretamente (ver SECURITY.md §7, FINDING-001/002/008).

# ─── Ambiente ───────────────────────────────────────────────
# Valores aceitos: development | staging | production | prod
ENV=development

# true apenas em dev. Produção rejeita no startup.
DEBUG=true

# ─── Segurança ──────────────────────────────────────────────
# OBRIGATÓRIO em produção. Gerar com: openssl rand -hex 32
# Em dev, deixar vazio autogenera um secret temporário.
SECRET_KEY=

# OBRIGATÓRIO em produção (lista explícita, sem wildcard).
# Em dev, deixar vazio auto-popula localhost:3000,3030,5055.
ALLOWED_ORIGINS=

# Secret opcional para validar webhook do Evolution (HMAC).
# Se preenchido, webhook com assinatura inválida será rejeitado.
EVOLUTION_WEBHOOK_SECRET=

# ─── Banco de dados ─────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/connectaiacare
REDIS_URL=redis://localhost:6380/5

# ─── Evolution API (WhatsApp) ────────────────────────────────
# Evolution API compartilhado com ConnectaIA (mesmo container evolution_v2).
# Instância DEDICADA ao ConnectaIACare (chip próprio: 5551994548043).
# Decisão em ADR-013.
EVOLUTION_API_URL=https://evolution.connectaia.com.br
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=connectaiacare

# ─── IA ─────────────────────────────────────────────────────
# Provider do LLM: "anthropic" (default) | "gemini"
# Em produção, OBRIGATÓRIO setar a key correspondente ao provider ativo.
LLM_PROVIDER=anthropic

# Anthropic Claude (default — análise clínica, extração de entidades)
ANTHROPIC_API_KEY=

# Google Gemini (alternativa — usar com LLM_PROVIDER=gemini)
# Chave gratuita em https://aistudio.google.com/apikey (tier free 1500 RPD)
GOOGLE_API_KEY=

# Deepgram (STT pt-BR nova-2) — NÃO muda entre providers
DEEPGRAM_API_KEY=

# Sofia Voz (ligações proativas via Grok). Opcional em dev.
# Em rede Docker interna use hostname: http://sofia-service:5030
SOFIA_VOICE_API_URL=
SOFIA_VOICE_API_KEY=

# ─── Outros ────────────────────────────────────────────────
PUBLIC_BASE_URL=https://demo.connectaia.com.br
LOG_LEVEL=INFO
TENANT_ID=connectaiacare_demo
